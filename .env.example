# ── Server Configuration ──────────────────────────────────────────────────────
PORT=10000
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string — replace <user>, <password>, <cluster>, <dbname>
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Authentication ───────────────────────────────────────────────────────────
# JWT secret — must be at least 32 characters
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=09eea3669726ea01f05938d171bafb83
JWT_EXPIRES_IN=7d

# ── URLs ─────────────────────────────────────────────────────────────────────
